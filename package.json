{
  "name": "automation-assignment",
  "version": "1.0.0",
  "description": "Automation Anywhere Community Edition — Playwright + TypeScript test suite (UC1: UI, UC2: API)",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui/formUploadFlow.spec.ts --headed",
    "test:api": "playwright test tests/api/apiAutomationFlow.spec.ts --headed",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "dotenv": "^16.4.0",
    "typescript": "^5.4.0"
  }
}
